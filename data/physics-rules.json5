{
  rules: [
    {
      // Fire spreads to adjacent tiles with flammable materials
      trigger: "on_fire",
      propagatesTo: {
        condition: "adjacent",
        materialProperty: "flammability",
        threshold: 0.3,
        effect: "on_fire",
        delay: 1,
      },
      consumedBy: ["wet", "vacuum"],
      damagePerTurn: 3,
      burnStatusOnOrganic: true,
    },
    {
      // Wet state — does not propagate, suppresses fire
      trigger: "wet",
      propagatesTo: null,
      consumedBy: [],
      duration: 5,
    },
    {
      // Charged state — propagates through conductors
      trigger: "charged",
      propagatesTo: {
        condition: "adjacent",
        materialProperty: "conductivity",
        threshold: 0.5,
        effect: "charged",
        delay: 0,
      },
      consumedBy: [],
    },
  ],

  // Fluid-fire interactions
  fluidFireInteractions: {
    // Fluids with suppresses_fire tag extinguish fire and apply wet
    suppressors: ["water"],
    // Fluids with intensifies_fire tag lower fire spread threshold
    intensifiers: ["oil"],
    intensifierThresholdMultiplier: 0.3,
  },

  // Gas interaction rules
  gasRules: {
    // Toxic gas: damages organic entities standing in it
    toxicDamagePerTurn: 2,
    toxicThreshold: 0.2,  // minimum concentration to deal damage

    // Flammable gas: explodes when fire is present
    flammableExplosionThreshold: 0.3,  // minimum concentration to explode
    explosionDamage: 15,
    explosionRadius: 2,  // tiles from center
  },
}
