{
  // Room function definitions for procedural ship generation.
  // Each room function has a weight (likelihood of assignment),
  // population table (species + density), and optional features.

  rooms: [
    {
      id: "bridge",
      name: "Bridge",
      weight: 1,           // only one per ship typically
      maxCount: 1,
      // Population: species id → { weight, min, max per room }
      population: [
        { species: "security_bot", weight: 3, min: 0, max: 1 },
        { species: "drone_scout", weight: 2, min: 0, max: 1 },
      ],
      loot: { min: 1, max: 3 },
      // Infrastructure tile features
      infrastructure: ["console", "conduit"],
      // Arrival state events that can pre-exist
      arrivalEvents: ["fire", "gas_leak"],
    },
