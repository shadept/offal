{
  id: "drone_scout",
  name: "Scout Drone",
  description: "Small autonomous recon unit. Fast, fragile, curious.",
  speed: 120,
  fovRange: 10,
  color: "#33aa88",
  spawnTags: ["mechanical"],
  faction: "security",
  maxHp: 8,
  attackDamage: 2,

  parts: [
    { id: "core",       role: "torso",  position: "front",    default: "drone_core" },
    { id: "rotor_l",    role: "rotor",  position: "left",     default: "drone_rotor" },
    { id: "rotor_r",    role: "rotor",  position: "right",    default: "drone_rotor" },
    { id: "sensors",    role: "sensor", position: "top",      default: "drone_sensors" },
    { id: "power_core", role: "organ",  position: "internal", default: "drone_power_core" },
  ],

  compatibleWith: ["metal"],
  requiredParts: ["power_core"],
  locomotionBaseline: "hover",
}
